@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "Home";
}

<div class="container mt-5">
    <!-- Hero Section -->
    <div class="text-center mb-5">
        <h1 class="display-4">
            <i class="fa-solid fa-briefcase"></i> Welcome to FSM
        </h1>
        <p class="lead">Connecting freelancers with clients based on skills, passion, and expertise.</p>
        
        <a asp-controller="" asp-action="" class="btn btn-outline-primary btn-lg me-2">
            <i class="fa-solid fa-users"></i> Browse Freelancers
        </a>

        <a asp-controller="Project" asp-action="Create" class="btn btn-outline-secondary btn-lg">
            <i class="fa-solid fa-plus"></i> Post a Project
        </a>
    </div>

    <!-- Features Section -->
    <div class="row text-center mb-5">
        <div class="col-md-4">
            <a asp-controller="" asp-action="" class="text-decoration-none text-dark">
                <i class="fa-solid fa-magnifying-glass fa-3x mb-3 text-primary"></i>
                <h3>Discover Talent</h3>
                <p>Search and filter freelancers by skills, ratings, and availability.</p>
            </a>
        </div>
        <div class="col-md-4">
            <a asp-controller="" asp-action="" class="text-decoration-none text-dark">
                <i class="fa-solid fa-handshake fa-3x mb-3 text-success"></i>
                <h3>Collaborate Easily</h3>
                <p>Post projects, manage tasks, and communicate seamlessly.</p>
            </a>
        </div>
        <div class="col-md-4">
            <a asp-controller="" asp-action="" class="text-decoration-none text-dark">
                <i class="fa-solid fa-chart-line fa-3x mb-3 text-warning"></i>
                <h3>Grow Together</h3>
                <p>Track progress, share feedback, and build long‑term partnerships.</p>
            </a>
        </div>
    </div>


    <!-- Call to Action -->
    <div class="bg-dark text-light text-center p-4 rounded">
        <h2>Ready to get started?</h2>
        <p>Join FSM today and showcase your skills or find the perfect freelancer for your project.</p>
        <a asp-controller="" asp-action="" class="btn btn-success btn-lg">
            <i class="fa-solid fa-user-plus"></i> Sign Up Now
        </a>
    </div>
</div>
