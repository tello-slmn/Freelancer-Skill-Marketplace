@{
    ViewData["Title"] = "Home";
}

<div class="container mt-4">
    <!-- Hero Section -->
    <div class="text-center mb-5">
        <h1 class="display-4 text-primary">
            <i class="fa-solid fa-laptop-code"></i> Freelancer Skill Marketplace
        </h1>
        <p class="lead">Connecting talented freelancers with clients worldwide.</p>
        <a asp-controller="Project" asp-action="Create" class="btn btn-success btn-lg me-2">
            <i class="fa-solid fa-handshake"></i> Post a Project
        </a>
        <a asp-controller="Project" asp-action="Index" class="btn btn-outline-primary btn-lg">
            <i class="fa-solid fa-magnifying-glass"></i> Browse Projects
        </a>
    </div>

    <!-- Features Section -->
    <div class="row text-center mb-5">
        <div class="col-md-4">
            <a asp-controller="Freelancer" asp-action="Index" " class="text-decoration-none text-dark">
                <i class="fa-solid fa-magnifying-glass fa-3x mb-3 text-primary"></i>
                <h3>Discover Talent</h3>
                <p>Search and filter freelancers by skills, ratings, and availability.</p>
            </a>
        </div>
        <div class="col-md-4">
            <a asp-controller="" asp-action="" class="text-decoration-none text-dark">
                <i class="fa-solid fa-handshake fa-3x mb-3 text-success"></i>
                <h3>Collaborate Easily</h3>
                <p>Post projects, manage tasks, and communicate seamlessly.</p>
            </a>
        </div>
        <div class="col-md-4">
            <a asp-controller="" asp-action="" class="text-decoration-none text-dark">
                <i class="fa-solid fa-chart-line fa-3x mb-3 text-warning"></i>
                <h3>Grow Together</h3>
                <p>Track progress, share feedback, and build long‑term partnerships.</p>
            </a>
        </div>
    </div>

    <!-- About & Contact Section -->
    <div class="row justify-content-center">
        <div class="col-md-5 mb-3">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <i class="fa-solid fa-circle-info fa-2x text-secondary mb-2"></i>
                    <h4>About Us</h4>
                    <p>Learn more about our mission and vision.</p>
                    <a asp-controller="Home" asp-action="About" class="btn btn-outline-secondary">Read More</a>
                </div>
            </div>
        </div>
        <div class="col-md-5 mb-3">
            <div class="card shadow-sm">
                <div class="card-body text-center">
                    <i class="fa-solid fa-envelope fa-2x text-secondary mb-2"></i>
                    <h4>Contact Us</h4>
                    <p>Get in touch with our team today.</p>
                    <a asp-controller="Home" asp-action="Contact" class="btn btn-outline-secondary">Reach Out</a>
                </div>
            </div>
        </div>
    </div>
</div>
