@{
    ViewData["Title"] = "About";
}

<div class="container mt-4">
    <h1 class="text-center mb-4">
        <i class="fa-solid fa-circle-info"></i> About Us
    </h1>

    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-body">
                    <p class="lead">
                        Welcome to the Freelancer Skill Marketplace (FSM). Our mission is to connect talented freelancers with clients worldwide.
                    </p>
                    <p>
                        We provide a platform where clients can post projects, freelancers can showcase their skills, and both parties can collaborate effectively.
                    </p>
                    <p>
                        Built with ASP.NET Core MVC, EF Core, Bootstrap, and Font Awesome, FSM demonstrates modern web development practices and clean UI design.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
