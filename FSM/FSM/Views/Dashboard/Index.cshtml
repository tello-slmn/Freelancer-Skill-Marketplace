@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mt-4">
    <h1><i class="fa-solid fa-chart-line"></i> Dashboard</h1>

    <div class="row">
        <div class="col-md-4">
            <div class="card text-center">
                <div class="card-body">
                    <i class="fa-solid fa-briefcase fa-2x mb-2 text-primary"></i>
                    <h5 class="card-title">My Projects</h5>
                    <p class="card-text">View and manage your posted projects.</p>
                    <a href="/Projects" class="btn btn-outline-primary">Go</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center">
                <div class="card-body">
                    <i class="fa-solid fa-envelope fa-2x mb-2 text-success"></i>
                    <h5 class="card-title">Messages</h5>
                    <p class="card-text">Check your latest conversations.</p>
                    <a href="/Messages" class="btn btn-outline-success">Go</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center">
                <div class="card-body">
                    <i class="fa-solid fa-user fa-2x mb-2 text-warning"></i>
                    <h5 class="card-title">Profile</h5>
                    <p class="card-text">Update your skills and details.</p>
                    <a href="/Profile" class="btn btn-outline-warning">Go</a>
                </div>
            </div>
        </div>
    </div>
</div>