@model IEnumerable<Project>
@{
    ViewData["Title"] = "Projects";
}

<h1 class="mb-4 text-center">
    <i class="fa-solid fa-magnifying-glass"></i> Search Projects by filtering
</h1>

<!-- Search bar -->
<form asp-controller="" asp-action="" method="get" class="mb-4">
    <div class="input-group">
        <input type="text" name="searchString" class="form-control" placeholder="Search projects..." />
        <button type="submit" class="btn btn-primary">
            <i class="fa-solid fa-search"></i> Search
        </button>
    </div>
</form>

<div class="container mt-4">
    <h1 class="mb-4 text-center">
        <i class="fa-solid fa-handshake"></i> Projects
    </h1>

    <div class="row">
        @foreach (var p in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title text-primary">
                            <i class="fa-solid fa-briefcase"></i> @p.ProjectTitle
                        </h5>
                        <p class="card-text">@p.ProjectDescription</p>
                        <p><strong>Budget:</strong> R @p.ProjectBudget</p>
                        <p><strong>Status:</strong> @p.ProjectStatus</p>
                        <p><small class="text-muted">Posted on @p.ProjectPostedDate.ToString("d")</small></p>
                    </div>
                    <div class="card-footer text-center">
                        <a asp-controller="Project" asp-action="Details" asp-route-projectId="@p.ProjectID" 
                           class="btn btn-outline-primary btn-sm">
                            <i class="fa-solid fa-eye"></i> View Details
                        </a>
                        <a asp-controller="Project" asp-action="" asp-route-id="@p.ProjectID" 
                           class="btn btn-success btn-sm">
                            <i class="fa-solid fa-paper-plane"></i> Apply
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>