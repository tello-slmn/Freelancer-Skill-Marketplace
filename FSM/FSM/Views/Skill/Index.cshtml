@model IEnumerable<Skill>

@{
    ViewData["Title"] = "Browse Skills";
}

<div class="container mt-4">
    <h1 class="mb-4 text-center">
        <i class="fa-solid fa-magnifying-glass"></i> Browse Skills
    </h1>

    <!-- Search bar -->
    <form asp-controller="Skills" asp-action="Index" method="get" class="mb-4">
        <div class="input-group">
            <input type="text" name="searchString" class="form-control" placeholder="Search skills..." />
            <button type="submit" class="btn btn-primary">
                <i class="fa-solid fa-search"></i> Search
            </button>
        </div>
    </form>

    <!-- Skills table -->
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>Skill Name</th>
                <th>Level</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var skill in Model)
            {
                <tr>
                    <td>@skill.SkillName</td>
                    <td>@skill.SkillLevel</td>
                </tr>
            }
        </tbody>
    </table>
</div>
